          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "title": "İstek Log Tablosu (Metod / Rota / Durum Kodu)",
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["method", "route", "status", "Value"] } } },
        { "id": "sortBy",             "options": { "fields": [{ "desc": true, "displayName": "Value" }] } }
